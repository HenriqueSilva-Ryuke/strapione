{
  "kind": "collectionType",
  "collectionName": "category_projects",
  "info": {
    "singularName": "category-project",
    "pluralName": "category-projects",
    "displayName": "CategoryProject"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
