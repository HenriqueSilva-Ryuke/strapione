      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "slug": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "targetField": "title"
    },
    "projectos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::projecto.projecto",
      "mappedBy": "category_project"
    },
    "portfolio_galerias": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::portfolio-galeria.portfolio-galeria",
      "mappedBy": "category_project"
    }
  }
}
